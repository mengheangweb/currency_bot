generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int      @id @default(autoincrement())
  telegramId      BigInt   @unique
  username        String?
  defaultCurrency String   @default("USD")
  alertsEnabled   Boolean  @default(true)
  preferredShopId Int?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  conversions     Conversion[]
  histories       ConversionHistory[]
  alerts          RateAlert[]

  @@map("users")
}

model ExchangeShop {
  id         Int      @id @default(autoincrement())
  name       String
  location   String
  latitude   Float?
  longitude  Float?
  contact    String?
  telegram   String?
  isActive   Boolean  @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  rates      Rate[]

  @@map("exchange_shops")
}

model Rate {
  id        Int      @id @default(autoincrement())
  currency  String
  buyRate   Float
  sellRate  Float

  shopId    Int
  shop      ExchangeShop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([currency])
  @@map("rates")
}

model Conversion {
  id           Int      @id @default(autoincrement())

  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fromCurrency String
  toCurrency   String
  amount       Float
  result       Float

  createdAt    DateTime @default(now())

  @@map("conversions")
}

model ConversionHistory {
  id        Int      @id @default(autoincrement())

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount    Float
  currency  String
  result    Float

  createdAt DateTime @default(now())

  @@map("conversion_history")
}

model RateAlert {
  id         Int      @id @default(autoincrement())

  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  currency   String
  targetRate Float?

  createdAt  DateTime @default(now())

  @@map("rate_alerts")
}